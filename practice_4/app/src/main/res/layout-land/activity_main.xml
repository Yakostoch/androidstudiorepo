<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#10131A"
    android:padding="24dp"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/imageViewCover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#1B2330"
        android:contentDescription="Album cover"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.38"
        tools:ignore="UseAppTint" />

    <TextView
        android:id="@+id/textViewNowPlayingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="Now Playing"
        android:textColor="#A9B4C5"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/imageViewCover"
        app:layout_constraintTop_toTopOf="@id/imageViewCover" />

    <TextView
        android:id="@+id/textViewMirea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:text="Midnight City"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/imageViewCover"
        app:layout_constraintTop_toBottomOf="@id/textViewNowPlayingLabel" />

    <EditText
        android:id="@+id/editTextMirea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#506176"
        android:ems="10"
        android:hint="Artist name"
        android:inputType="text"
        android:text="M83"
        android:textColor="#DCE6F2"
        android:textColorHint="#6D7B8F"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/imageViewCover"
        app:layout_constraintTop_toBottomOf="@id/textViewMirea" />

    <TextView
        android:id="@+id/textViewCurrentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="1:24"
        android:textColor="#A9B4C5"
        android:textSize="13sp"
        app:layout_constraintStart_toEndOf="@id/imageViewCover"
        app:layout_constraintTop_toBottomOf="@id/editTextMirea" />

    <TextView
        android:id="@+id/textViewDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3:46"
        android:textColor="#A9B4C5"
        android:textSize="13sp"
        app:layout_constraintBaseline_toBaselineOf="@id/textViewCurrentTime"
        app:layout_constraintEnd_toEndOf="parent" />

    <SeekBar
        android:id="@+id/seekBarTrack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:max="100"
        android:progress="38"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/imageViewCover"
        app:layout_constraintTop_toBottomOf="@id/textViewCurrentTime" />

    <ImageButton
        android:id="@+id/buttonPrevious"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:background="#1B2330"
        android:contentDescription="Previous track"
        android:padding="14dp"
        android:src="@android:drawable/ic_media_previous"
        app:layout_constraintStart_toEndOf="@id/imageViewCover"
        app:layout_constraintTop_toBottomOf="@id/seekBarTrack"
        app:tint="#FFFFFF" />

    <Button
        android:id="@+id/buttonMirea"
        android:layout_width="88dp"
        android:layout_height="56dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:backgroundTint="#4C8DFF"
        android:text="Play"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/buttonPrevious"
        app:layout_constraintStart_toEndOf="@id/buttonPrevious"
        app:layout_constraintTop_toTopOf="@id/buttonPrevious" />

    <ImageButton
        android:id="@+id/buttonNext"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="#1B2330"
        android:contentDescription="Next track"
        android:layout_marginStart="24dp"
        android:padding="14dp"
        android:src="@android:drawable/ic_media_next"
        app:layout_constraintBottom_toBottomOf="@id/buttonPrevious"
        app:layout_constraintStart_toEndOf="@id/buttonMirea"
        app:layout_constraintTop_toTopOf="@id/buttonPrevious"
        app:tint="#FFFFFF" />

</androidx.constraintlayout.widget.ConstraintLayout>
